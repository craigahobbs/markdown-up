include '../unittest.bare'
include '../unittestMock.bare'


# Start coverage
unittestCoverageStart()

# Run markdownUp.bare unit tests
include 'testMarkdownUp.bare'

# Stop coverage
unittestCoverageStop()

# Test report
return unittestReport(objectNew('minCoverage', 36))
